using System;

class Program {
    static void Main()
    {
        int[] marks = new int[5] {85, 92, 78, 88, 95};
        
        int total = 0;
        
        for(int i = 0; i < marks.Length; i++)
        {
            total += marks[i];
        }
        
        double average = (double)total / marks.Length;
        Console.WriteLine("Total marks: " + total);
        Console.WriteLine("Average: " + average);
    }
}
